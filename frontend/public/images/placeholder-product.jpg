<svg viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg" width="600" height="600">
  <!-- Background -->
  <rect width="600" height="600" fill="#1a1a2e"/>
  
  <!-- Image icon -->
  <g transform="translate(150, 150)">
    <!-- Camera frame -->
    <rect x="0" y="0" width="300" height="300" fill="#404959" stroke="#656d7e" stroke-width="2"/>
    
    <!-- Mountain shapes (abstract image) -->
    <polygon points="0,200 100,100 150,150 200,75 300,200 300,300 0,300" fill="#5a6b7a" opacity="0.8"/>
    
    <!-- Circle (sun) -->
    <circle cx="240" cy="80" r="30" fill="#ffa502" opacity="0.7"/>
  </g>
  
  <!-- Text -->
  <text x="300" y="500" font-size="32" font-family="Arial, sans-serif" fill="#a0a9b8" text-anchor="middle" font-weight="bold">
    No Product Image
  </text>
  
  <!-- Decorative line -->
  <line x1="150" y1="520" x2="450" y2="520" stroke="#656d7e" stroke-width="2"/>
</svg>
