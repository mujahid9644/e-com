# Frontend Environment Variables - Production
# This is used by Next.js when building for production

# Production API URL - Points to Render backend
NEXT_PUBLIC_API_URL=https://e-com-u0eh.onrender.com/api

# Google OAuth (from .env.local)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=

# Stripe Public Key (Optional)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
